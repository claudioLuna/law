# Configuración de entorno para el sistema de soporte WhatsApp
# Copia este archivo a .env y configura tus valores

# === CONFIGURACIÓN GENERAL ===
DOMAIN=localhost
ENVIRONMENT=production

# === BASE DE DATOS ===
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_password_super_secure_123

# === N8N CONFIGURACIÓN ===
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123_secure
N8N_WEBHOOK_URL=https://your-n8n-instance.com
N8N_HOST=0.0.0.0
N8N_PROTOCOL=https

# === SUPABASE CONFIGURACIÓN ===
SUPABASE_URL=https://supabase.localhost
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long-for-security

# === OPENAI / CLAUDE ===
OPENAI_API_KEY=your-openai-api-key-here
# Para usar Claude via OpenAI-compatible API
OPENAI_BASE_URL=https://api.anthropic.com/v1

# === KAPSO CONFIGURACIÓN ===
KAPSO_API_KEY=your-kapso-api-key-here

# === WHATSAPP INTEGRACIÓN ===
WHATSAPP_WEBHOOK_TOKEN=your-whatsapp-webhook-token
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token

# === NOTIFICACIONES ===
# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# === JIRA INTEGRACIÓN ===
JIRA_HOST=https://your-company.atlassian.net
JIRA_EMAIL=your-jira-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=SUP

# === REDIS ===
REDIS_PASSWORD=redis_password_secure_123

# === TRAEFIK / SSL ===
ACME_EMAIL=admin@your-domain.com

# === MONITOREO ===
GRAFANA_PASSWORD=grafana_admin_password_123

# === DOKPLOY ESPECÍFICO ===
# Variables adicionales para Dokploy
DOKPLOY_PROJECT_NAME=soporte-whatsapp
DOKPLOY_DOMAIN=your-domain.com
DOKPLOY_SSL_EMAIL=ssl@your-domain.com

# === DESARROLLO ===
# Activar servicios de desarrollo
COMPOSE_PROFILES=dev

# === SEGURIDAD ===
# Tokens de seguridad adicionales
API_SECRET_KEY=your-api-secret-key-for-internal-auth
WEBHOOK_SECRET=your-webhook-secret-for-validation

# === LOGS Y DEBUGGING ===
LOG_LEVEL=info
DEBUG_MODE=false

# === BACKUP ===
# Configuración para backups automáticos
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_ACCESS_KEY=your-s3-access-key
BACKUP_S3_SECRET_KEY=your-s3-secret-key
BACKUP_RETENTION_DAYS=30

# === MÉTRICAS Y ANALYTICS ===
# Para integración con servicios de analytics
ANALYTICS_API_KEY=your-analytics-api-key
MIXPANEL_TOKEN=your-mixpanel-token

# === RATE LIMITING ===
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# === CACHE ===
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=100