# Legal AI System Configuration
# Copy this file to .env and fill in your actual values

# Google Service Account Credentials
# Get these from your Google Cloud Console Service Account
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=your-client-id

# OpenAI Configuration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Gmail Configuration
# Set up OAuth2 credentials for Gmail API access
GMAIL_USER_EMAIL=your-email@gmail.com
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token

# Legal Team Configuration
LEGAL_TEAM_EMAIL=legal-team@yourfirm.com

# Google Sheets IDs (will be generated by setup scripts)
LEGAL_SUMMARIES_SHEET_ID=
CONTRACT_ANALYSIS_SHEET_ID=

# Google Drive Folder IDs (will be generated by setup scripts)
COMPLAINTS_CONTRACTS_FOLDER_ID=
CONTRACT_ANALYSIS_FOLDER_ID=

# N8N Configuration
N8N_HOST=http://localhost:5678
N8N_API_KEY=your-n8n-api-key

# Optional: Custom configurations
# Document processing settings
DOCUMENT_PROCESSING_ENABLED=true
CONTRACT_ANALYSIS_ENABLED=true
EMAIL_NOTIFICATIONS_ENABLED=true

# AI Model Settings
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2000

# Email Settings
EMAIL_SUBJECT_PREFIX="[Legal AI]"
EMAIL_HTML_FORMATTING=true

# Google Drive Settings
DRIVE_FOLDER_PERMISSIONS=writer
DRIVE_SHARE_WITH_DOMAIN=false

# Logging and Monitoring
LOG_LEVEL=info
ENABLE_DEBUG_MODE=false