# =============================================================================
# CONFIGURACIÓN - Agente Legal IA Argentina (Mendoza)
# =============================================================================
# Copia este archivo a .env y configura las variables según tu entorno

# =============================================================================
# BASE DE DATOS POSTGRESQL
# =============================================================================
PG_HOST=postgres
PG_DB=legal
PG_USER=legal_user
PG_PASS=CAMBIAR_PASSWORD_AQUI

# =============================================================================
# QDRANT (BASE DE DATOS VECTORIAL)
# =============================================================================
QDRANT_URL=http://qdrant:6333

# =============================================================================
# REDIS (CACHE Y RATE LIMITING)
# =============================================================================
REDIS_HOST=redis

# =============================================================================
# OPENAI API (LLM Y EMBEDDINGS)
# =============================================================================
OPENAI_API_KEY=sk-xxx
EMBEDDINGS_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4o

# =============================================================================
# EVOLUTIONAPI (WHATSAPP)
# =============================================================================
EVOLUTION_BASE_URL=http://evolutionapi:8080
EVOLUTION_INSTANCE=legal-agent
EVOLUTION_API_KEY=token123

# =============================================================================
# WEBHOOK PÚBLICO (CONFIGURAR SEGÚN TU DOMINIO)
# =============================================================================
BASE_URL=https://agentlaw.midominio.com

# =============================================================================
# TOKEN DE SETUP (SEGURIDAD)
# =============================================================================
SETUP_TOKEN=legal-agent-2024

# =============================================================================
# CONFIGURACIÓN OPCIONAL
# =============================================================================
# Timezone
GENERIC_TIMEZONE=America/Argentina/Mendoza

# Logs
N8N_LOG_LEVEL=info

# Métricas
N8N_METRICS=true

# Diagnósticos
N8N_DIAGNOSTICS_ENABLED=false