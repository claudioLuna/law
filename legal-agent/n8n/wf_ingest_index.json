    {
      "parameters": {
        "functionCode": "// Validar entrada y preparar datos\nconst inputData = $input.first().json;\n\n// Verificar si es multipart/form-data (archivo) o JSON (URL)\nlet fileData = null;\nlet fileInfo = {};\nlet sourceText = '';\nlet metadata = {};\n\nif (inputData.file) {\n  // Archivo subido via multipart\n  fileData = inputData.file;\n  fileInfo = {\n    filename: fileData.filename || 'documento.pdf',\n    mime: fileData.mimetype || 'application/pdf',\n    size: fileData.size || 0\n  };\n  \n  // Extraer texto del archivo (simulado - en producción usar librería real)\n  if (fileData.mimetype.includes('pdf')) {\n    sourceText = 'TEXTO EXTRAÍDO DEL PDF: Lorem ipsum dolor sit amet...'; // Simulado\n  } else if (fileData.mimetype.includes('docx')) {\n    sourceText = 'TEXTO EXTRAÍDO DEL DOCX: Lorem ipsum dolor sit amet...'; // Simulado\n  } else {\n    sourceText = 'TEXTO EXTRAÍDO: Lorem ipsum dolor sit amet...'; // Simulado\n  }\n} else if (inputData.url) {\n  // URL para descargar\n  fileInfo = {\n    filename: inputData.filename || 'documento_descargado.pdf',\n    mime: inputData.mime || 'application/pdf',\n    size: 0\n  };\n  sourceText = 'TEXTO DESCARGADO DE URL: Lorem ipsum dolor sit amet...'; // Simulado\n} else {\n  throw new Error('Se requiere archivo o URL');\n}\n\n// Metadatos del documento\nmetadata = {\n  case_id: inputData.case_id || null,\n  fuente: inputData.fuente || 'upload',\n  documento: inputData.documento || fileInfo.filename,\n  jurisdiction: inputData.jurisdiction || 'Mendoza',\n  date: inputData.date || new Date().toISOString().split('T')[0],\n  tags: inputData.tags || ''\n};\n\n// Generar hash del contenido\nconst crypto = require('crypto');\nconst hash = crypto.createHash('sha256').update(sourceText).digest('hex');\n\n// Generar ID único para el documento\nconst docId = require('uuid').v4();\n\nreturn {\n  json: {\n    doc_id: docId,\n    file_info: fileInfo,\n    source_text: sourceText,\n    metadata: metadata,\n    hash_sha256: hash,\n    original_input: inputData\n  }\n};"
      },
