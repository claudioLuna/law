    {
      "parameters": {
        "functionCode": "// Función para dividir texto en chunks\nfunction chunkText(text, chunkSize = 1500, overlap = 200) {\n  const chunks = [];\n  const words = text.split(' ');\n  \n  for (let i = 0; i < words.length; i += chunkSize - overlap) {\n    const chunk = words.slice(i, i + chunkSize).join(' ');\n    const tokens = chunk.split(' ').length; // Estimación simple\n    \n    chunks.push({\n      text: chunk,\n      tokens: tokens,\n      chunk_index: chunks.length,\n      page: Math.floor(i / 500) + 1 // Estimación de página\n    });\n  }\n  \n  return chunks;\n}\n\nconst docData = $input.first().json;\nconst sourceText = docData.source_text;\n\n// Crear chunks del texto\nconst chunks = chunkText(sourceText, 1500, 200);\n\nreturn chunks.map((chunk, index) => ({\n  json: {\n    doc_id: docData.doc_id,\n    chunk_index: chunk.chunk_index,\n    text: chunk.text,\n    tokens: chunk.tokens,\n    page: chunk.page,\n    metadata: {\n      ...docData.metadata,\n      chunk_index: chunk.chunk_index,\n      page: chunk.page,\n      tokens: chunk.tokens\n    }\n  }\n}));"
      },
      "id": "function-create-chunks",
      "name": "Crear Chunks del Texto",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1340, 280]
